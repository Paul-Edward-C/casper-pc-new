{{!-- Shared banner for custom pages: the page's own title on sage green, with
     a dark bamboo band along the bottom. Include with an explicit title:
        {{> "page-banner" title="China"}}
     or with no arg to fall back to the current page's {{title}}. --}}
<div class="page-banner">
    <h1 class="pb-title">{{title}}</h1>
    <div class="pb-band pb-band-bottom" aria-hidden="true"></div>
</div>
