{{!-- Custom-page banner: same lockup as the home banner, but the PAGE NAME takes
     the big left slot and the brand wordmark sits on the right.
        {{> "page-banner" title="China"}}   (or no arg to use the page's {{title}}) --}}
<div class="page-banner">
    <div class="page-banner-inner">
        <div class="pb-name">{{title}}</div>
        <span class="pb-divider" aria-hidden="true"></span>
        <img class="pb-mark" src="{{asset "images/logo_mark.png"}}" alt="" aria-hidden="true" />
        <div class="pb-brand">
            <span class="pb-brand-title">East Asia Econ</span>
            <span class="pb-brand-sub">Paul Cavey</span>
        </div>
    </div>
</div>
