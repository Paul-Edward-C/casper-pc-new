{{!< default}}
{{!-- The tag above means: insert everything in this file
into the {body} tag of the default.hbs template --}}

{{#match @custom.publication_cover_style "!=" "None"}}
    <div class="site-header-content{{#match @custom.publication_cover_style "Large"}} large{{/match}}">
        {{#if @site.cover_image}}
            <img class="site-header-cover"
                srcset="{{img_url @site.cover_image size="s"}} 300w,
                        {{img_url @site.cover_image size="m"}} 600w,
                        {{img_url @site.cover_image size="l"}} 1000w,
                        {{img_url @site.cover_image size="xl"}} 2000w"
                sizes="100vw"
                src="{{img_url @site.cover_image size="s"}}"
                alt=""
            />
        {{/if}}
        <h1 class="site-title">
            {{#if @site.logo}}
                <img class="site-logo" src="{{img_url @site.logo size="m"}}" alt="{{@site.title}}" />
            {{else}}
                Data API
            {{/if}}
        </h1>
    </div>
{{/match}}

<div id="site-main" class="site-main outer">
    <main id="site-main" class="site-main outer">
        <div class="outer">
            {{#page}}
            <article class="post-full {{post_class}} no-image">
                <section class="post-full-content">
                    <div class="post-content">
                        {{{content}}}
                    </div>
                </section>
            </article>
            {{/page}}
        </div>

        <!-- API Demo Section -->
        <div class="api-demo-container gh-canvas">

            <div class="info-box">
                <strong>API Endpoint:</strong> <code>https://data-api-production-74e0.up.railway.app</code><br>
                <strong>Coverage:</strong> China, Japan, Korea, Taiwan + Regional data<br>
                <strong>Series:</strong> 246,000+ monthly economic indicators<br>
                <strong>Access:</strong> Search is free. Data download requires <a href="#/portal/signup" class="api-link">subscription</a>.
            </div>

            <h2 class="api-section-title">Search for Data Series</h2>

            <div class="search-container">
                <input type="text" id="search-input" placeholder="Search (e.g., CPI, GDP, exports, inflation)..." value="CPI">
                <select id="freq-select">
                    <option value="m">Monthly</option>
                </select>
                <select id="country-select">
                    <option value="">All Countries</option>
                    <option value="cn">China</option>
                    <option value="jp">Japan</option>
                    <option value="kr">Korea</option>
                    <option value="tw">Taiwan</option>
                    <option value="region">Regional</option>
                </select>
                <button onclick="searchSeries()" class="api-button">Search</button>
            </div>

            <div class="api-call" id="search-api-call">
                GET /v3/search?q=CPI&freq=m&limit=15
            </div>

            <div id="search-status" class="status" style="display:none;"></div>

            <div class="results-container" id="results-container">
                <p><em>Enter a search term and click Search to find data series.</em></p>
            </div>

            <h2 class="api-section-title">Data: <span id="selected-series">Select a series above</span></h2>

            <div class="api-call" id="data-api-call" style="display:none;">
                GET /v3/series/{series_name}
            </div>

            <div id="chart-container"></div>

            <div id="data-table-container">
                <p><em>Data will appear here when you select a series.</em></p>
            </div>

        </div>
    </main>
</div>


<style>
    .api-demo-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .api-section-title {
        color: #104b1f;
        margin-top: 30px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen", "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans", "Helvetica Neue", sans-serif;
    }

    .info-box {
        background: rgba(16, 75, 31, 0.1);
        border-left: 4px solid #104b1f;
        padding: 15px;
        margin: 20px 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen", "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans", "Helvetica Neue", sans-serif;
    }

    .info-box code {
        background: rgba(16, 75, 31, 0.15);
        padding: 2px 6px;
        border-radius: 3px;
    }

    .api-link {
        color: #104b1f;
        text-decoration: underline;
    }

    .search-container {
        display: flex;
        gap: 10px;
        margin: 20px 0;
        flex-wrap: wrap;
    }

    .search-container input[type="text"] {
        flex: 1;
        min-width: 200px;
        padding: 12px 15px;
        font-size: 16px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
        border: 2px solid #104b1f;
        border-radius: 5px;
    }

    .search-container select {
        padding: 12px 15px;
        font-size: 16px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
        border: 2px solid #104b1f;
        border-radius: 5px;
        background: white;
    }

    .api-button {
        padding: 12px 25px;
        font-size: 16px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
        background-color: #104b1f;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s ease;
        font-weight: bold;
    }

    .api-button:hover {
        background-color: rgba(16, 75, 31, 0.7);
    }

    .results-container {
        margin: 20px 0;
    }

    .result-item {
        padding: 12px 15px;
        margin: 5px 0;
        background: rgba(16, 75, 31, 0.05);
        border-left: 4px solid #104b1f;
        cursor: pointer;
        transition: background-color 0.2s;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
    }

    .result-item:hover {
        background: rgba(16, 75, 31, 0.15);
    }

    .result-item.selected {
        background: rgba(16, 75, 31, 0.2);
        border-left-color: #B7410E;
    }


    .api-call {
        background: #2d2d2d;
        color: #98c379;
        padding: 15px;
        border-radius: 5px;
        font-family: 'Courier New', monospace;
        font-size: 14px;
        overflow-x: auto;
        margin: 10px 0;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
        font-size: 14px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
    }

    .data-table th {
        background: #104b1f;
        color: white;
        padding: 10px;
        text-align: left;
    }

    .data-table td {
        padding: 8px 10px;
        border-bottom: 1px solid #ddd;
    }

    .data-table tr:nth-child(even) {
        background: rgba(16, 75, 31, 0.05);
    }

    .status {
        padding: 10px;
        margin: 10px 0;
        border-radius: 5px;
    }

    .status.loading {
        background: #fff3cd;
        color: #856404;
    }

    .status.error {
        background: #f8d7da;
        color: #721c24;
    }

    .status.success {
        background: #d4edda;
        color: #155724;
    }

    #selected-series {
        font-weight: bold;
        color: #B7410E;
    }

    .subscription-message {
        text-align: center;
        padding-top: 80px;
    }

    .subscription-message h3 {
        color: #104b1f;
        margin-bottom: 15px;
    }

    .subscription-message p {
        color: #666;
        max-width: 400px;
        margin: 0 auto;
    }

    .subscription-message .api-button {
        display: inline-block;
        margin-top: 20px;
        text-decoration: none;
    }
</style>

<script>
    // Configuration
    const API_BASE = 'https://data-api-production-74e0.up.railway.app';

    // Member status from Ghost
    const isMember = {{#if @member}}true{{else}}false{{/if}};
    const memberEmail = {{#if @member}}'{{@member.email}}'{{else}}null{{/if}};

    // API key for authenticated members only
    {{#if @member}}
    const API_KEY = 'ghost-member-access-2024';
    {{else}}
    const API_KEY = null;
    {{/if}}

    // Search for series (using fast v3 endpoint)
    async function searchSeries() {
        const query = document.getElementById('search-input').value;
        const freq = document.getElementById('freq-select').value;
        const country = document.getElementById('country-select').value;

        if (!query.trim()) {
            showStatus('search-status', 'Please enter a search term', 'error');
            return;
        }

        // Build URL - use v3 endpoint
        let url = `${API_BASE}/v3/search?q=${encodeURIComponent(query)}&freq=${freq}&limit=15`;
        if (country) {
            url += `&country=${country}`;
        }

        // Show API call
        document.getElementById('search-api-call').textContent =
            `GET /v3/search?q=${query}&freq=${freq}${country ? '&country=' + country : ''}&limit=15`;

        showStatus('search-status', 'Searching...', 'loading');

        try {
            const response = await fetch(url);
            const data = await response.json();

            if (data.results && data.results.length > 0) {
                displayResults(data.results);
                showStatus('search-status', `Found ${data.count} series`, 'success');
            } else {
                document.getElementById('results-container').innerHTML =
                    '<p><em>No results found. Try a different search term.</em></p>';
                showStatus('search-status', 'No results found', 'error');
            }
        } catch (error) {
            showStatus('search-status', `Error: ${error.message}`, 'error');
        }
    }

    // Display search results (v3 returns objects with metadata)
    function displayResults(results) {
        const container = document.getElementById('results-container');
        container.innerHTML = results.map(item => {
            const name = item.name;
            const country = item.country ? item.country.toUpperCase() : '';
            const count = item.count || '';
            const dateRange = item.min_date && item.max_date ?
                `${item.min_date.slice(0,7)} to ${item.max_date.slice(0,7)}` : '';
            return `<div class="result-item" onclick="selectSeries('${escapeHtml(name)}')">
                <strong>${name}</strong>
                <span style="float:right;color:#666;font-size:12px;">${country} | ${count} obs | ${dateRange}</span>
            </div>`;
        }).join('');
    }

    // Select a series and load data (using fast v3 endpoint)
    async function selectSeries(name) {
        // Highlight selected
        document.querySelectorAll('.result-item').forEach(el => el.classList.remove('selected'));
        event.target.closest('.result-item').classList.add('selected');

        document.getElementById('selected-series').textContent = name;

        // Show API call - v3 uses path parameter
        const apiCall = `GET /v3/series/${encodeURIComponent(name)}`;
        document.getElementById('data-api-call').textContent = apiCall;
        document.getElementById('data-api-call').style.display = 'block';

        // Fetch data - v3 endpoint with path parameter
        const url = `${API_BASE}/v3/series/${encodeURIComponent(name)}`;

        document.getElementById('chart-container').innerHTML =
            '<p class="chart-placeholder">Loading data...</p>';

        try {
            const fetchOptions = {};
            if (API_KEY) {
                fetchOptions.headers = { 'X-API-Key': API_KEY };
            }
            const response = await fetch(url, fetchOptions);
            const data = await response.json();

            if (data.data && data.data.length > 0) {
                document.getElementById('chart-container').innerHTML = '';
                displayDataTable(data.series_name || name, data.data);
            } else if (data.detail && data.detail.includes('Authentication')) {
                if (isMember) {
                    // Logged-in member - direct to data app
                    document.getElementById('chart-container').innerHTML = `
                        <div class="subscription-message">
                            <h3>Access Full Data</h3>
                            <p>
                                As a subscriber, you have full access to download data.
                                Use the Data Explorer for interactive charts and downloads.
                            </p>
                            <a href="https://eae-data.fly.dev" target="_blank" class="api-button">
                                Open Data Explorer
                            </a>
                        </div>`;
                } else {
                    // Not logged in
                    document.getElementById('chart-container').innerHTML = `
                        <div class="subscription-message">
                            <h3>Subscription Required</h3>
                            <p>
                                Data access requires an active subscription.
                                Subscribe to get full access to all economic data series.
                            </p>
                            <a href="#/portal/signup" class="api-button">
                                Subscribe Now
                            </a>
                        </div>`;
                }
                document.getElementById('data-table-container').innerHTML = '';
            } else if (data.detail) {
                document.getElementById('chart-container').innerHTML =
                    `<p class="chart-placeholder" style="color:#B7410E;">${data.detail}</p>`;
            } else {
                document.getElementById('chart-container').innerHTML =
                    '<p class="chart-placeholder">No data available</p>';
            }
        } catch (error) {
            document.getElementById('chart-container').innerHTML =
                `<p class="chart-placeholder" style="color:#B7410E;">Error: ${error.message}</p>`;
        }
    }

    // Display data table (v3 format: {Date, value})
    function displayDataTable(seriesName, data) {
        const container = document.getElementById('data-table-container');

        // Get last 20 rows
        const recentData = data.slice(-20).reverse();

        let html = `
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
        `;

        recentData.forEach(row => {
            const value = row.value;
            const formattedValue = value !== null && value !== undefined
                ? (typeof value === 'number' ? value.toLocaleString(undefined, {maximumFractionDigits: 2}) : value)
                : '-';
            html += `<tr><td>${row.Date}</td><td>${formattedValue}</td></tr>`;
        });

        html += '</tbody></table>';
        html += `<p><em>Showing most recent 20 of ${data.length} observations for: ${seriesName}</em></p>`;

        container.innerHTML = html;
    }

    // Helper functions
    function showStatus(elementId, message, type) {
        const el = document.getElementById(elementId);
        el.textContent = message;
        el.className = `status ${type}`;
        el.style.display = 'block';
    }

    function escapeHtml(text) {
        return text.replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }

    // Search on Enter key
    document.getElementById('search-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') searchSeries();
    });
</script>
