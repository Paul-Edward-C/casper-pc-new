{{!< default}}
{{!-- The tag above means: insert everything in this file
into the {body} tag of the default.hbs template --}}

<main id="site-main" class="site-main">
<article class="article">

    <header class="article-header gh-canvas">
        <h1 class="article-title">Data API</h1>
    </header>

    <section class="gh-content gh-canvas">
        {{#page}}{{{content}}}{{/page}}
    </section>

        <!-- API Demo Section -->
        <div class="api-demo-container gh-canvas">

            <div class="info-box">
                <strong>API Endpoint:</strong> <code>https://data-api-production-74e0.up.railway.app</code><br>
                <strong>Coverage:</strong> China, Japan, Korea, Taiwan + Regional data<br>
                <strong>Series:</strong> 246,000+ monthly economic indicators<br>
                <strong>Access:</strong> Search is free. Data download requires <a href="#/portal/signup" class="api-link">subscription</a>.
            </div>

            <hr class="section-divider">

            <!-- Tab bar -->
            <div class="tab-bar">
                <button class="tab-button active" onclick="switchTab('search')">Search</button>
                <button class="tab-button" onclick="switchTab('docs')">Documentation</button>
            </div>

            <!-- Search tab (visible by default) -->
            <div id="tab-search">

            <h2 class="api-section-title">Search for Data Series</h2>

            <div class="search-container">
                <input type="text" id="search-input" placeholder="Search (e.g., CPI, GDP, exports, inflation)..." value="CPI">
                <select id="freq-select">
                    <option value="m">Monthly</option>
                </select>
                <select id="country-select">
                    <option value="">All Countries</option>
                    <option value="cn">China</option>
                    <option value="jp">Japan</option>
                    <option value="kr">Korea</option>
                    <option value="tw">Taiwan</option>
                    <option value="region">Regional</option>
                </select>
                <button onclick="searchSeries()" class="api-button">Search</button>
            </div>

            <div class="api-call" id="search-api-call">
                GET /v3/search?q=CPI&freq=m&limit=15
            </div>

            <div id="search-status" class="status" style="display:none;"></div>

            <div class="results-container" id="results-container">
                <p><em>Enter a search term and click Search to find data series.</em></p>
            </div>

            <hr class="section-divider">

            <h2 class="api-section-title">Data: <span id="selected-series">Select a series above</span></h2>

            <div class="api-call" id="data-api-call" style="display:none;">
                GET /v3/series/{series_name}
            </div>

            <div id="chart-container">
                <canvas id="data-chart"></canvas>
            </div>

            <div id="data-table-container">
                <p><em>Data will appear here when you select a series.</em></p>
            </div>

            </div><!-- /tab-search -->

            <!-- Documentation tab (hidden by default) -->
            <div id="tab-docs" style="display:none;">

            <h2 class="api-section-title" id="getting-started">Getting Started</h2>

            <p class="docs-text">
                The East Asia Econ Data API provides programmatic access to 246,000+ monthly economic indicators
                covering China, Japan, Korea, Taiwan, and regional aggregates. Follow these three steps to start
                pulling data into your own scripts and models.
            </p>

            <div class="docs-steps">
                <div class="docs-step">
                    <div class="docs-step-number">1</div>
                    <div class="docs-step-content">
                        <h3>Subscribe</h3>
                        <p>
                            <a href="#/portal/signup" data-portal="signup" class="api-link">Create a free account</a>
                            or subscribe to a paid tier for higher limits. All members get an API key.
                        </p>
                    </div>
                </div>
                <div class="docs-step">
                    <div class="docs-step-number">2</div>
                    <div class="docs-step-content">
                        <h3>Get Your API Key</h3>
                        <p>
                            Visit the <a href="/api-keys/" class="api-link">API Keys page</a> while signed in.
                            Your personal key (starting with <code>eae_</code>) will be generated automatically.
                            Copy it and keep it private.
                        </p>
                    </div>
                </div>
                <div class="docs-step">
                    <div class="docs-step-number">3</div>
                    <div class="docs-step-content">
                        <h3>Make Requests</h3>
                        <p>
                            Pass your key in the <code>X-API-Key</code> header. Search is open to everyone;
                            data download requires authentication.
                        </p>
                    </div>
                </div>
            </div>

            <hr class="section-divider">

            <h2 class="api-section-title" id="rate-limits">Rate Limits</h2>

            <table class="docs-table">
                <thead>
                    <tr>
                        <th>Membership Tier</th>
                        <th>Monthly Limit</th>
                        <th>Best For</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Free</td>
                        <td>10 series lookups</td>
                        <td>Trying out the API</td>
                    </tr>
                    <tr>
                        <td>Daily</td>
                        <td>30 series lookups</td>
                        <td>Regular monitoring</td>
                    </tr>
                    <tr>
                        <td>Daily + Data / East Asia</td>
                        <td>Unlimited</td>
                        <td>Research and modelling</td>
                    </tr>
                </tbody>
            </table>

            <p class="docs-text">
                Usage resets on the 1st of each month (UTC). You can check your current usage on
                the <a href="/api-keys/" class="api-link">API Keys page</a> or via the
                <code>GET /usage</code> endpoint.
            </p>

            <hr class="section-divider">

            <h2 class="api-section-title" id="endpoints">API Endpoints</h2>

            <table class="docs-table">
                <thead>
                    <tr>
                        <th>Endpoint</th>
                        <th>Auth?</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>GET /v3/search?q=...&freq=m</code></td>
                        <td>No</td>
                        <td>Search for series by keyword. Returns name, country, date range, obs count.</td>
                    </tr>
                    <tr>
                        <td><code>GET /v3/series/{name}</code></td>
                        <td>Yes</td>
                        <td>Download data for a series. Optional <code>start</code> and <code>end</code> date filters.</td>
                    </tr>
                    <tr>
                        <td><code>GET /v3/info/{name}</code></td>
                        <td>No</td>
                        <td>Get metadata (date range, frequency, obs count) without downloading data.</td>
                    </tr>
                    <tr>
                        <td><code>GET /v3/stats</code></td>
                        <td>No</td>
                        <td>Summary statistics: total series, breakdowns by country and frequency.</td>
                    </tr>
                    <tr>
                        <td><code>GET /usage</code></td>
                        <td>Yes</td>
                        <td>Your current usage and rate limit status.</td>
                    </tr>
                </tbody>
            </table>

            <p class="docs-text">
                <strong>Base URL:</strong> <code>https://data-api-production-74e0.up.railway.app</code>
            </p>

            <hr class="section-divider">

            <h2 class="api-section-title" id="python-example">Python Example</h2>

            <p class="docs-text">
                Copy the script below and replace <code>YOUR_KEY_HERE</code> with the key from
                your <a href="/api-keys/" class="api-link">API Keys page</a>. Requires only the
                <code>requests</code> library (<code>pip install requests</code>).
            </p>

            <div class="docs-code">
<pre><code>import requests

API_KEY = "YOUR_KEY_HERE"
BASE    = "https://data-api-production-74e0.up.railway.app"

# ── 1. Search for series ──────────────────────────────────
results = requests.get(f"{BASE}/v3/search", params={
    "q": "CPI",
    "freq": "m",
    "country": "jp",
    "limit": 5
}).json()

print(f"Found {results['count']} series matching 'CPI' (Japan, monthly)\n")
for s in results["results"]:
    print(f"  {s['name']}  ({s['count']} obs, {s['min_date'][:7]} to {s['max_date'][:7]})")

# ── 2. Download data for one series ───────────────────────
series_name = results["results"][0]["name"]
data = requests.get(
    f"{BASE}/v3/series/{series_name}",
    headers={"X-API-Key": API_KEY},
    params={"start": "2020-01-01"}
).json()

print(f"\n{series_name}")
print(f"{data['count']} observations from {data['min_date']} to {data['max_date']}\n")

# ── 3. Convert to pandas DataFrame ───────────────────────
import pandas as pd

df = pd.DataFrame(data["data"])
df["Date"] = pd.to_datetime(df["Date"])
df = df.set_index("Date")

print(df.tail(10))

# ── 4. Check your usage ──────────────────────────────────
usage = requests.get(
    f"{BASE}/usage",
    headers={"X-API-Key": API_KEY}
).json()

u = usage["usage"]
print(f"\nUsage this month: {u['requests_used']} / {u['requests_limit'] or 'unlimited'}")</code></pre>
            </div>

            <hr class="section-divider">

            <h2 class="api-section-title" id="authentication">Authentication</h2>

            <p class="docs-text">
                Include your API key in the <code>X-API-Key</code> header on every request that
                requires authentication:
            </p>

            <div class="docs-code">
<pre><code># Python (requests)
response = requests.get(url, headers={"X-API-Key": "eae_your_key_here"})

# curl
curl -H "X-API-Key: eae_your_key_here" "https://data-api-production-74e0.up.railway.app/v3/series/Japan,%20CPI,%20Crude%20oil,%20JPY"

# JavaScript (fetch)
fetch(url, { headers: { "X-API-Key": "eae_your_key_here" } })</code></pre>
            </div>

            <p class="docs-text">
                If your key is compromised, visit the <a href="/api-keys/" class="api-link">API Keys page</a>
                and click <strong>Regenerate Key</strong>. Your old key will stop working immediately.
            </p>

            <hr class="section-divider">

            <h2 class="api-section-title" id="response-format">Response Format</h2>

            <p class="docs-text">
                All endpoints return JSON. A typical data response from <code>/v3/series/</code>:
            </p>

            <div class="docs-code">
<pre><code>{
  "series_name": "Japan, CPI, Crude oil, JPY",
  "country": "jp",
  "frequency": "m",
  "count": 784,
  "min_date": "1960-01-01",
  "max_date": "2025-04-01",
  "data": [
    {"Date": "2024-01-01", "value": 12082.85},
    {"Date": "2024-02-01", "value": 11934.33},
    ...
  ],
  "rate_limit": {
    "used": 3,
    "limit": null,
    "remaining": null,
    "tier": "premium",
    "period": "monthly",
    "month": "2026-01"
  }
}</code></pre>
            </div><!-- /tab-docs -->

        </div>

</article>
</main>


