<!-- Chart.js library with zoom plugin -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom"></script>

<script>
    // Configuration
    const API_BASE = 'https://data-api-production-74e0.up.railway.app';

    // Member status from Ghost
    const isMember = {{#if @member}}true{{else}}false{{/if}};
    const memberEmail = {{#if @member}}'{{@member.email}}'{{else}}null{{/if}};

    // API key for authenticated members — fetched from /keys/provision
    let API_KEY = null;

    {{#if @member}}
    // Provision per-user key on page load
    (async function() {
        try {
            const resp = await fetch(
                `${API_BASE}/keys/provision?email=${encodeURIComponent(memberEmail)}`,
                { method: 'POST' }
            );
            if (resp.ok) {
                const data = await resp.json();
                API_KEY = data.api_key;
            }
        } catch (e) {
            console.warn('Could not provision API key:', e);
        }
    })();
    {{/if}}

    // Chart instance
    let dataChart = null;
    let currentTool = 'pan';

    // Background image for chart area (loaded once)
    const bgImage = new Image();
    bgImage.src = 'https://www.eastasiaecon.com/content/images/size/w2400/2023/04/Image-29-4-2023-at-7.34-PM.jpeg';

    // Chart.js plugin to draw background in chart area only
    const chartAreaBgPlugin = {
        id: 'chartAreaBg',
        beforeDraw: (chart) => {
            const ctx = chart.ctx;
            const chartArea = chart.chartArea;
            if (!chartArea) return;

            ctx.save();

            // Draw green background fill (5% alpha like Bokeh)
            ctx.fillStyle = 'rgba(34, 139, 34, 0.05)';
            ctx.fillRect(chartArea.left, chartArea.top, chartArea.width, chartArea.height);

            // Draw background image at 12% opacity (like Bokeh)
            if (bgImage.complete) {
                ctx.globalAlpha = 0.12;
                ctx.drawImage(bgImage, chartArea.left, chartArea.top, chartArea.width, chartArea.height);
                ctx.globalAlpha = 1;
            }

            ctx.restore();
        }
    };

    // Plugin to draw horizontal line at zero (like Bokeh Span)
    const zeroLinePlugin = {
        id: 'zeroLine',
        beforeDraw: (chart) => {
            const ctx = chart.ctx;
            const chartArea = chart.chartArea;
            const yScale = chart.scales.y;
            if (!chartArea || !yScale) return;

            // Only draw if zero is within the visible range
            const yMin = yScale.min;
            const yMax = yScale.max;
            if (yMin > 0 || yMax < 0) return;

            const yPixel = yScale.getPixelForValue(0);

            ctx.save();
            ctx.strokeStyle = '#333';
            ctx.lineWidth = 1;
            ctx.setLineDash([]);
            ctx.beginPath();
            ctx.moveTo(chartArea.left, yPixel);
            ctx.lineTo(chartArea.right, yPixel);
            ctx.stroke();
            ctx.restore();
        }
    };

    // Tool switching for chart
    function setChartTool(tool) {
        currentTool = tool;
        // Update button states
        document.querySelectorAll('.chart-toolbar button').forEach(btn => {
            btn.classList.remove('active');
        });
        const activeBtn = document.getElementById('tool-' + tool);
        if (activeBtn) activeBtn.classList.add('active');

        // Update chart zoom/pan settings
        if (dataChart) {
            const zoomEnabled = (tool === 'zoom');
            const panEnabled = (tool === 'pan');
            dataChart.options.plugins.zoom.zoom.wheel.enabled = zoomEnabled;
            dataChart.options.plugins.zoom.pan.enabled = panEnabled;
            dataChart.update('none');
        }
    }

    // Search for series (using fast v3 endpoint)
    async function searchSeries() {
        const query = document.getElementById('search-input').value;
        const freq = document.getElementById('freq-select').value;
        const country = document.getElementById('country-select').value;

        if (!query.trim()) {
            showStatus('search-status', 'Please enter a search term', 'error');
            return;
        }

        // Build URL - use v3 endpoint
        let url = `${API_BASE}/v3/search?q=${encodeURIComponent(query)}&freq=${freq}&limit=15`;
        if (country) {
            url += `&country=${country}`;
        }

        // Show API call
        document.getElementById('search-api-call').textContent =
            `GET /v3/search?q=${query}&freq=${freq}${country ? '&country=' + country : ''}&limit=15`;

        showStatus('search-status', 'Searching...', 'loading');

        try {
            const response = await fetch(url);
            const data = await response.json();

            if (data.results && data.results.length > 0) {
                displayResults(data.results);
                showStatus('search-status', `Found ${data.count} series`, 'success');
            } else {
                document.getElementById('results-container').innerHTML =
                    '<p><em>No results found. Try a different search term.</em></p>';
                showStatus('search-status', 'No results found', 'error');
            }
        } catch (error) {
            showStatus('search-status', `Error: ${error.message}`, 'error');
        }
    }

    // Display search results (v3 returns objects with metadata)
    function displayResults(results) {
        const container = document.getElementById('results-container');
        container.innerHTML = results.map(item => {
            const name = item.name;
            const country = item.country ? item.country.toUpperCase() : '';
            const count = item.count || '';
            const dateRange = item.min_date && item.max_date ?
                `${item.min_date.slice(0,7)} to ${item.max_date.slice(0,7)}` : '';
            return `<div class="result-item" onclick="selectSeries('${escapeHtml(name)}')">
                <strong>${name}</strong>
                <span style="float:right;color:#666;font-size:12px;">${country} | ${count} obs | ${dateRange}</span>
            </div>`;
        }).join('');
    }

    // Select a series and load data (using fast v3 endpoint)
    async function selectSeries(name) {
        // Highlight selected
        document.querySelectorAll('.result-item').forEach(el => el.classList.remove('selected'));
        event.target.closest('.result-item').classList.add('selected');

        document.getElementById('selected-series').textContent = name;

        // Show API call - v3 uses path parameter
        const apiCall = `GET /v3/series/${encodeURIComponent(name)}`;
        document.getElementById('data-api-call').textContent = apiCall;
        document.getElementById('data-api-call').style.display = 'block';

        // Fetch data - v3 endpoint with path parameter
        const url = `${API_BASE}/v3/series/${encodeURIComponent(name)}`;

        // Clear chart and show loading
        if (dataChart) {
            dataChart.destroy();
            dataChart = null;
        }
        document.getElementById('chart-container').innerHTML =
            '<p class="chart-placeholder">Loading data...</p>';

        try {
            const fetchOptions = {};
            if (API_KEY) {
                fetchOptions.headers = { 'X-API-Key': API_KEY };
            }
            const response = await fetch(url, fetchOptions);
            const data = await response.json();

            if (data.data && data.data.length > 0) {
                document.getElementById('chart-container').innerHTML = `
                    <div class="chart-toolbar">
                        <button onclick="setChartTool('pan')" id="tool-pan" title="Pan" class="active">
                            <svg viewBox="0 0 24 24"><path d="M10 9h4V6h3l-5-5-5 5h3v3zm-1 1H6V7l-5 5 5 5v-3h3v-4zm14 2l-5-5v3h-3v4h3v3l5-5zm-9 3h-4v3H7l5 5 5-5h-3v-3z"/></svg>
                        </button>
                        <button onclick="setChartTool('zoom')" id="tool-zoom" title="Wheel Zoom">
                            <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/><path d="M12 10h-2v2H9v-2H7V9h2V7h1v2h2v1z"/></svg>
                        </button>
                        <button onclick="resetChartZoom()" title="Reset">
                            <svg viewBox="0 0 24 24"><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
                        </button>
                        <button onclick="downloadChart()" title="Save">
                            <svg viewBox="0 0 24 24"><path d="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2v9.67z"/></svg>
                        </button>
                    </div>
                    <canvas id="data-chart"></canvas>`;
                renderChart(data.series_name || name, data.data);
                displayDataTable(data.series_name || name, data.data);
            } else if (data.detail && data.detail.includes('Authentication')) {
                if (isMember) {
                    // Logged-in member - direct to data app
                    document.getElementById('chart-container').innerHTML = `
                        <div class="subscription-message">
                            <h3>Access Full Data</h3>
                            <p>
                                As a subscriber, you have full access to download data.
                                Use the Data Explorer for interactive charts and downloads.
                            </p>
                            <a href="https://eae-data.fly.dev" target="_blank" class="api-button">
                                Open Data Explorer
                            </a>
                        </div>`;
                } else {
                    // Not logged in
                    document.getElementById('chart-container').innerHTML = `
                        <div class="subscription-message">
                            <h3>Subscription Required</h3>
                            <p>
                                Data access requires an active subscription.
                                Subscribe to get full access to all economic data series.
                            </p>
                            <a href="#/portal/signup" class="api-button">
                                Subscribe Now
                            </a>
                        </div>`;
                }
                document.getElementById('data-table-container').innerHTML = '';
            } else if (data.detail) {
                document.getElementById('chart-container').innerHTML =
                    `<p class="chart-placeholder" style="color:#B7410E;">${data.detail}</p>`;
            } else {
                document.getElementById('chart-container').innerHTML =
                    '<p class="chart-placeholder">No data available</p>';
            }
        } catch (error) {
            document.getElementById('chart-container').innerHTML =
                `<p class="chart-placeholder" style="color:#B7410E;">Error: ${error.message}</p>`;
        }
    }

    // Render chart using Chart.js - styled to match cn_auto_exports Bokeh app
    function renderChart(seriesName, data) {
        // Destroy existing chart if any
        if (dataChart) {
            dataChart.destroy();
        }

        const ctx = document.getElementById('data-chart').getContext('2d');

        // Prepare data - use last 120 data points (10 years of monthly data)
        const chartData = data.slice(-120);
        const labels = chartData.map(d => d.Date);
        const values = chartData.map(d => d.value);

        dataChart = new Chart(ctx, {
            type: 'line',
            plugins: [chartAreaBgPlugin, zeroLinePlugin],
            data: {
                labels: labels,
                datasets: [{
                    label: seriesName,
                    data: values,
                    borderColor: '#556B2F',  // Dark olive green - matches Bokeh app
                    backgroundColor: 'transparent',
                    borderWidth: 3,  // Matches Bokeh line_width=3
                    fill: false,
                    tension: 0,
                    pointRadius: 0,
                    pointHoverRadius: 6,
                    pointHoverBackgroundColor: '#556B2F',
                    pointHoverBorderColor: '#556B2F'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false  // Not needed for single series
                    },
                    title: {
                        display: false
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#556B2F',
                        bodyColor: '#556B2F',
                        borderColor: '#A9A9A9',
                        borderWidth: 0.5,
                        titleFont: {
                            family: 'Georgia, serif',
                            size: 14,
                            weight: 'bold'
                        },
                        bodyFont: {
                            family: 'Georgia, serif',
                            size: 14
                        },
                        padding: 10,
                        callbacks: {
                            title: function(tooltipItems) {
                                // Format date as "Jan 2024" like Bokeh app
                                const label = tooltipItems[0].label;
                                if (label) {
                                    const date = new Date(label);
                                    if (!isNaN(date)) {
                                        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                                        return months[date.getMonth()] + ' ' + date.getFullYear();
                                    }
                                }
                                return label;
                            },
                            label: function(context) {
                                // Format as "0,0.0" like Bokeh (1 decimal place)
                                return context.parsed.y.toLocaleString(undefined, {minimumFractionDigits: 1, maximumFractionDigits: 1});
                            }
                        }
                    },
                    zoom: {
                        pan: {
                            enabled: true,
                            mode: 'x'
                        },
                        zoom: {
                            wheel: {
                                enabled: true
                            },
                            pinch: {
                                enabled: true
                            },
                            mode: 'x'
                        }
                    }
                },
                scales: {
                    x: {
                        display: true,
                        grid: {
                            display: false
                        },
                        ticks: {
                            maxTicksLimit: 10,
                            font: {
                                family: 'Georgia, serif',
                                size: 14
                            },
                            color: '#333',
                            callback: function(value, index, ticks) {
                                // Format dates like my_functions.py line_chart:
                                // >= 84 months: show years only ("2020")
                                // < 84 months: show "Jan-24" format
                                const label = this.getLabelForValue(value);
                                if (label) {
                                    const date = new Date(label);
                                    if (!isNaN(date)) {
                                        // Check total data span
                                        const firstLabel = this.getLabelForValue(0);
                                        const lastLabel = this.getLabelForValue(ticks.length - 1);
                                        const firstDate = new Date(firstLabel);
                                        const lastDate = new Date(lastLabel);
                                        const monthSpan = (lastDate.getFullYear() - firstDate.getFullYear()) * 12 +
                                                         (lastDate.getMonth() - firstDate.getMonth());

                                        if (monthSpan >= 84) {
                                            // Year mode: show just year
                                            return date.getFullYear().toString();
                                        } else {
                                            // Month mode: show "Jan-24" format
                                            const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                                            const year = date.getFullYear().toString().slice(-2);
                                            return months[date.getMonth()] + '-' + year;
                                        }
                                    }
                                }
                                return label;
                            }
                        },
                        border: {
                            color: '#999'
                        }
                    },
                    y: {
                        display: true,
                        grid: {
                            color: 'rgba(0, 0, 0, 0.1)',
                            lineWidth: 1
                        },
                        ticks: {
                            font: {
                                family: 'Georgia, serif',
                                size: 14  // Larger like Bokeh
                            },
                            color: '#333',
                            callback: function(value) {
                                // Format as "0,0.0" like Bokeh
                                return value.toLocaleString(undefined, {minimumFractionDigits: 1, maximumFractionDigits: 1});
                            }
                        },
                        border: {
                            color: '#999'
                        }
                    }
                },
                interaction: {
                    mode: 'nearest',
                    axis: 'x',
                    intersect: false
                },
                elements: {
                    line: {
                        borderJoinStyle: 'round'
                    }
                }
            }
        });

        // Position toolbar to right of plot area
        positionToolbar();
    }

    // Position toolbar inside chart area on the right
    function positionToolbar() {
        if (!dataChart) return;
        const chartArea = dataChart.chartArea;
        if (!chartArea) return;

        const toolbar = document.querySelector('.chart-toolbar');
        if (!toolbar) return;

        // Position toolbar just inside the right edge of chartArea
        toolbar.style.top = (chartArea.top + 5) + 'px';
        toolbar.style.right = (document.getElementById('chart-container').offsetWidth - chartArea.right + 5) + 'px';
    }

    // Display data table (v3 format: {Date, value})
    function displayDataTable(seriesName, data) {
        const container = document.getElementById('data-table-container');

        // Get last 20 rows
        const recentData = data.slice(-20).reverse();

        let html = `
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
        `;

        recentData.forEach(row => {
            const value = row.value;
            const formattedValue = value !== null && value !== undefined
                ? (typeof value === 'number' ? value.toLocaleString(undefined, {maximumFractionDigits: 2}) : value)
                : '-';
            html += `<tr><td>${row.Date}</td><td>${formattedValue}</td></tr>`;
        });

        html += '</tbody></table>';
        html += `<p><em>Showing most recent 20 of ${data.length} observations for: ${seriesName}</em></p>`;

        container.innerHTML = html;
    }

    // Chart toolbar functions
    function resetChartZoom() {
        if (dataChart) {
            dataChart.resetZoom();
        }
    }

    function downloadChart() {
        if (dataChart) {
            const link = document.createElement('a');
            link.download = 'chart.png';
            link.href = document.getElementById('data-chart').toDataURL('image/png');
            link.click();
        }
    }

    // Helper functions
    function showStatus(elementId, message, type) {
        const el = document.getElementById(elementId);
        el.textContent = message;
        el.className = `status ${type}`;
        el.style.display = 'block';
    }

    function escapeHtml(text) {
        return text.replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }

    // Tab switching
    function switchTab(tab) {
        document.getElementById('tab-search').style.display = tab === 'search' ? 'block' : 'none';
        document.getElementById('tab-docs').style.display = tab === 'docs' ? 'block' : 'none';
        document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }

    // Search on Enter key
    document.getElementById('search-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') searchSeries();
    });
</script>
