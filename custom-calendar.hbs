
{{!< default}}{{!< default}}
{{!-- The tag above means: insert everything in this file
into the {body} tag of the default.hbs template --}}


{{> "page-banner" title="Calendar"}}

<div id="site-main" class="site-main outer">
{{!-- Everything inside the #post block pulls data from the post --}}
<main id="site-main" class="site-main outer">
    
        <header class="article-header gh-canvas">
            {{#if feature_image}}
            <figure class="article-image">
                {{!-- This is a responsive image, it loads different sizes depending on device
                https://medium.freecodecamp.org/a-guide-to-responsive-images-with-ready-to-use-templates-c400bd65c433 --}}
                <img
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w,
                            {{img_url feature_image size="xl"}} 2000w"
                    sizes="(min-width: 1400px) 1400px, 92vw"
                    src="{{img_url feature_image size="xl"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                />
                {{#if feature_image_caption}}
                    <figcaption>{{feature_image_caption}}</figcaption>
                {{/if}}
            </figure>
            {{/if}}
        </header>

</div>
<style>
  /* Region data-release calendar — embedded here in the template (not the post body).
     Cross-origin iframe framed in brand green, spaced below the banner, centred. */
  .region-calendar-embed {
    width: 100%;
    display: flex;
    justify-content: center;   /* centre the table on the page */
  }
  .region-calendar-embed iframe {
    display: block;
    width: 100%;
    max-width: 1300px;
    min-height: 1000px;
    margin: clamp(30px, 5vw, 60px) 0 clamp(44px, 6vw, 76px);  /* gap below banner · bottom space */
    border: 2px solid #204D39;                 /* brand deep-green frame */
    border-radius: 12px;
    background: #F0EDE4;                        /* cream — matches the table */
    box-shadow: 0 8px 26px rgba(32, 77, 57, 0.13);
  }
</style>

<div class="region-calendar-embed">
  <iframe
    src="https://main--beautiful-dolphin-db8ab2.netlify.app/charts/region/region_calendar"
    title="East Asia Econ — data release calendar"
    loading="lazy"></iframe>
</div>



{{#page}}
    <article class="post-full {{post_class}} no-image">

        <section class="post-full-content">
            <div class="post-content">
                {{content}}
            </div>   
        </section>

    </article>

{{/page}}

</main>
</div>
